.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

# Build artifacts
dist/
.vite/
.turbo/
*.tsbuildinfo

# Environment secrets
.env
.env.local
.env.*.local

# Test & coverage
coverage/
test-results/
.playwright/
playwright-report/

# Database
data/

# Paraglide compiled output
**/paraglide/

# Sisyphus agent state (plans, notepads, run-continuation, evidence)
.sisyphus/

# OS
.DS_Store
Thumbs.db

# TanStack Start
app.config.timestamp_*.js

# Turborepo prune
/out*
