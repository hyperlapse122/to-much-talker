# ============================================================
# To Much Talker - Environment Variables
# ============================================================
# Copy to .env and fill in values. Never commit .env.
# Required variables must be set. Optional have defaults.
# ============================================================

# --- Discord ---
# REQUIRED. Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# REQUIRED. Your Discord application/client ID
DISCORD_CLIENT_ID=

# --- OpenRouter ---
# OPTIONAL for now. Default OpenRouter API key (per-guild BYOK overrides this)
# The current bot scaffold stores per-guild API keys but does not yet read this
# env var at startup.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OPTIONAL. Comma-separated list of allowed TTS model IDs
# Default: google/gemini-3.1-flash-tts-preview,google/gemini-3.1-flash-tts-preview
OPENROUTER_ALLOWED_MODELS=google/gemini-3.1-flash-tts-preview,google/gemini-3.1-flash-tts-preview

# --- Database ---
# OPTIONAL. Connection URL. If omitted, uses SQLite at ./data/bot.db
# Postgres example: postgres://user:pass@localhost:5432/botdb
# SQLite example: sqlite://./data/bot.db
DATABASE_URL=

# --- Encryption ---
# REQUIRED. AES-256-GCM master key for encrypting per-guild API keys.
# Generate: yarn workspace @to-much-talker/server key:gen
MASTER_ENC_KEY=

# OPTIONAL. Current encryption key version (integer). Default: 1
# Increment when rotating keys; old versions remain for decryption
MASTER_ENC_KEY_VERSION=1

# --- Clustering ---
# OPTIONAL. Number of shards. Default: auto (1 shard per 2500 guilds)
TOTAL_SHARDS=auto

# OPTIONAL. Number of cluster processes. Default: CPU count
CLUSTER_COUNT=

# --- Logging ---
# OPTIONAL. Pino log level. Default: info
# Values: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# --- Playground (dev only) ---
# OPTIONAL. Port for playground app. Default: 5173
PLAYGROUND_PORT=5173

# --- Docs site ---
# OPTIONAL. Port for docs site. Default: 4000
DOCS_PORT=4000

# --- Bot behavior ---
# OPTIONAL. Max characters per TTS message. Default: 500
TTS_MAX_CHARS=500

# OPTIONAL. Text channel inactivity before idle leave (ms). Default: 300000 (5 min)
IDLE_TEXT_INACTIVITY_MS=300000
