{
  "name": "@to-much-talker/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "tmt-bot": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node --env-file=.env dist/index.js start",
    "dev": "yarn build && node --env-file=.env dist/index.js start",
    "key:gen": "yarn build && node dist/index.js key gen",
    "migrate": "yarn build && node --env-file=.env dist/index.js migrate",
    "cli": "node dist/index.js"
  },
  "dependencies": {
    "@discordjs/opus": "0.10.0",
    "@discordjs/voice": "0.19.2",
    "@to-much-talker/ai": "workspace:*",
    "@to-much-talker/config": "workspace:*",
    "@to-much-talker/crypto": "workspace:*",
    "@to-much-talker/db": "workspace:*",
    "@to-much-talker/i18n": "workspace:*",
    "@to-much-talker/settings-core": "workspace:*",
    "@to-much-talker/shared": "workspace:*",
    "commander": "14.0.3",
    "discord-hybrid-sharding": "3.0.1",
    "discord.js": "14.26.4",
    "pino": "10.3.1",
    "prism-media": "1.3.5"
  },
  "devDependencies": {
    "@to-much-talker/test-utils": "workspace:*",
    "@types/node": "25.7.0",
    "pino-pretty": "13.1.3",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  }
}
